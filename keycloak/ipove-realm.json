{
  "realm": "ipove-platform",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "buyer", "description": "Marketplace buyer" },
      { "name": "seller", "description": "Marketplace seller" },
      { "name": "admin", "description": "Platform administrator" }
    ]
  },
  "defaultRoles": ["buyer"],
  "clients": [
    {
      "clientId": "ipove-web",
      "name": "ipove.ai Web Application",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "ipove-backend",
      "name": "ipove.ai Backend Service",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin@ipove.ai",
      "email": "admin@ipove.ai",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "realmRoles": ["admin", "buyer", "seller"]
    },
    {
      "username": "buyer@test.com",
      "email": "buyer@test.com",
      "firstName": "Test",
      "lastName": "Buyer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "test123", "temporary": false }
      ],
      "realmRoles": ["buyer"]
    },
    {
      "username": "seller@test.com",
      "email": "seller@test.com",
      "firstName": "Test",
      "lastName": "Seller",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "test123", "temporary": false }
      ],
      "realmRoles": ["seller"]
    }
  ]
}

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-categories" author="ipove">
        <createTable tableName="categories">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_categories_tenant"
                             references="tenants(id)"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="uuid">
                <constraints foreignKeyName="fk_categories_parent"
                             references="categories(id)"/>
            </column>
            <column name="icon" type="varchar(50)"/>
            <column name="sort_order" type="int" defaultValueNumeric="0"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz"/>
            <column name="deleted_at" type="timestamptz"/>
        </createTable>

        <addUniqueConstraint tableName="categories"
                             columnNames="tenant_id, slug"
                             constraintName="uq_categories_tenant_slug"/>

        <createIndex tableName="categories" indexName="idx_categories_parent">
            <column name="parent_id"/>
        </createIndex>
    </changeSet>


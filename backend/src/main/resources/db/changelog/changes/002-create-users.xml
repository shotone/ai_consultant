<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-create-users" author="ipove">
        <createTable tableName="users">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_users_tenant"
                             references="tenants(id)"/>
            </column>
            <column name="keycloak_id" type="varchar(255)">
                <constraints unique="true"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="varchar(50)"/>
            <column name="avatar_url" type="text"/>
            <column name="role" type="varchar(20)" defaultValue="buyer">
                <constraints nullable="false"/>
            </column>
            <column name="is_verified" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz"/>
            <column name="deleted_at" type="timestamptz"/>
        </createTable>

        <addUniqueConstraint tableName="users"
                             columnNames="tenant_id, email"
                             constraintName="uq_users_tenant_email"/>

        <sql>
            ALTER TABLE users ADD CONSTRAINT chk_user_role
                CHECK (role IN ('buyer', 'seller', 'both'));
        </sql>

        <createIndex tableName="users" indexName="idx_users_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="users" indexName="idx_users_email">
            <column name="email"/>
        </createIndex>

        <createIndex tableName="users" indexName="idx_users_keycloak">
            <column name="keycloak_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
